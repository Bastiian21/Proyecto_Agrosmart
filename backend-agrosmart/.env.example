# =========================================================
# CONFIGURACIÓN BACKEND AGROSMART
# Copia este archivo a .env y completa los valores reales
# =========================================================

# --- BASE DE DATOS (RDS PostgreSQL) ---
DB_HOST=tu-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=db_agrosmart
DB_USER=postgres
DB_PASSWORD=tu_password_seguro

# --- SERVIDOR ---
PORT=3000

# --- SEGURIDAD ---
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria-min-32-chars
CORS_ORIGIN=*

# --- WEBPAY (Transbank) ---
# En integración los SDKs ya traen las credenciales de prueba.
# Si en algún momento pasas a producción real, descomenta:
# TBK_API_KEY_ID=...
# TBK_API_KEY_SECRET=...
# TBK_COMMERCE_CODE=...
